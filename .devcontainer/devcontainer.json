{
  "name": "AI Coding with MongoDB Workshop",
  "image": "ghcr.io/nestor-daza-mdb/ubuntu-aicoding:latest",
  "remoteUser": "root",
  "workspaceFolder": "/root/project",
  "overrideCommand": true,
  "postStartCommand": "bash /workspaces/ai-coding-with-mongodb-codespace/.devcontainer/post-start.sh",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Workshop API",
      "onAutoForward": "notify"
    }
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  },
  "customizations": {
    "vscode": {
      "extensions": ["mongodb.mongodb-vscode"]
    }
  }
}